# Per-machine NAS config — real path lives only on build/dev boxes.
# Use nas_config.example.json as the template; copy + edit on each machine
# that needs to point at a real share.
app/nas_config.json

# PyInstaller / Inno build artifacts
app/build/
app/dist/

# Generated by tools/render_version.py (regenerated each build)
# We keep version_info.txt tracked because dev runs (`python launcher.py`)
# need it to import without first invoking the render script.

# Python build caches
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# OS noise
.DS_Store
Thumbs.db

# Release artifacts — track CHANGELOG.md per version, but binaries are
# rebuildable from source via build.bat. NAS holds the canonical installer
# copies (see NAS-LAYOUT.md).
releases/**/*.exe
releases/**/*.rar
releases/**/*.zip
releases/**/*.app/
releases/**/mac/

# Research scratch (PSDs, fixtures) — track docs only if anything lands.
reserach/
